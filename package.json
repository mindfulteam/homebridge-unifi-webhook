{
  "name": "homebridge-unifi-webhook",
  "displayName": "UniFi Webhook",
  "type": "module",
  "version": "1.1.0-beta.2",
  "description": "Two-way UniFi Protect Alarm Manager bridge for HomeKit: momentary switches fire outgoing webhooks, and sensors are driven by incoming webhooks.",
  "author": "Mindful Team",
  "license": "Apache-2.0",
  "homepage": "https://github.com/mindfulteam/homebridge-unifi-webhook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindfulteam/homebridge-unifi-webhook.git"
  },
  "bugs": {
    "url": "https://github.com/mindfulteam/homebridge-unifi-webhook/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homekit",
    "unifi",
    "unifi-protect",
    "ubiquiti",
    "webhook",
    "alarm-manager",
    "siri"
  ],
  "main": "dist/index.js",
  "files": [
    "dist",
    "config.schema.json",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": "^22.10.0 || ^24.0.0",
    "homebridge": "^1.9.0 || ^2.0.0"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "rimraf ./dist && tsc",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --max-warnings=0 --fix",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "nodemon",
    "version:beta": "npm version prerelease --preid=beta",
    "deploy:pi": "bash scripts/deploy-pi.sh",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.0.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "homebridge": "^2.0.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.0"
  }
}
